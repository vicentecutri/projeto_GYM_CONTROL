generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum UserType {
  aluno
  instrutor
  admin
  recepcao
}

model usuarios {
  id            String      @id @default(uuid())
  nome          String      @db.VarChar(100)
  email         String      @unique @db.VarChar(100)
  senha_hash    String      @db.VarChar(255)
  tipo          UserType    @default(aluno)
  data_criacao  DateTime?   @default(now()) @db.Timestamptz(6)

  // Relações
  matriculas       matriculas[]
  treinos_como_aluno     treinos[] @relation("aluno_treinos")
  treinos_como_instrutor treinos[] @relation("instrutor_treinos")
}

model exercicios {
  id             Int            @id @default(autoincrement())
  nome           String         @db.VarChar(100)
  grupo_muscular String         @db.VarChar(50)
  descricao      String?         @db.Text
  itens_treino   itens_treino[]
}

model treinos {
  id           Int            @id @default(autoincrement())
  aluno_id     String
  instrutor_id String
  titulo       String         @db.VarChar(50)
  data_criacao DateTime?      @default(dbgenerated("CURRENT_DATE")) @db.Date
  ativo        Boolean?       @default(true)
  
  itens_treino itens_treino[]

  // Relações nomeadas para evitar conflito
  aluno     usuarios @relation("aluno_treinos", fields: [aluno_id], references: [id])
  instrutor usuarios @relation("instrutor_treinos", fields: [instrutor_id], references: [id])
}

model itens_treino {
  id                Int        @id @default(autoincrement())
  treino_id         Int
  exercicio_id      Int
  series            Int
  repeticoes        String?    @db.VarChar(20)
  carga             String?    @db.VarChar(20)
  descanso_segundos Int?       @default(60)

  exercicios exercicios @relation(fields: [exercicio_id], references: [id])
  treinos    treinos    @relation(fields: [treino_id], references: [id], onDelete: Cascade)
}

model planos {
  id            Int          @id @default(autoincrement())
  nome          String       @db.VarChar(50)
  preco         Decimal      @db.Decimal(10, 2)
  duracao_meses Int
  ativo         Boolean      @default(true)
  matriculas    matriculas[]
}

model matriculas {
  id          String      @id @default(uuid())
  usuario_id  String
  plano_id    Int
  data_inicio DateTime    @default(dbgenerated("CURRENT_DATE")) @db.Date
  data_fim    DateTime    @db.Date
  status      String?     @default("ativa") @db.VarChar(20)
  created_at  DateTime?   @default(now()) @db.Timestamptz(6)

  planos     planos       @relation(fields: [plano_id], references: [id])
  usuarios   usuarios     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  pagamentos pagamentos[]
}

model pagamentos {
  id               String     @id @default(uuid())
  matricula_id     String
  valor_pago       Decimal    @db.Decimal(10, 2)
  metodo_pagamento String     @db.VarChar(30)
  data_pagamento   DateTime?  @default(now()) @db.Timestamptz(6)

  matriculas matriculas @relation(fields: [matricula_id], references: [id])
}